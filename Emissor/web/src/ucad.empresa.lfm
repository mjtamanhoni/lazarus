  object ZQContaBancaria: TZQuery
    SQL.Strings = (
      'select '
      '  db.*'
      '  ,case db.tipo_conta '
      '    when 0 then ''Corrente (PF/PJ) - Movimentação diária'''
      '    when 1 then ''Poupança (PF) - Guardar e render dinheiro'''
      '    when 2 then ''Salário (PF) - Receber salário/benefícios'''
      '    when 3 then ''Universitária/Jovem (Estudantes/jovens) - Condições especiais'''
      '    when 4 then ''PJ/MEI (Empresas/autônomos) - Gestão financeira empresarial'''
      '    when 5 then ''Digital (PF/PJ) - Movimentação online'''
      '    when 6 then ''Investimento (PF/PJ) - Aplicações financeiras'''
      '    when 7 then ''Conjunta (PF) - Compartilhar recursos'''
      '  end tipo_conta_desc'
      'from public.dados_bancarios db '
      'where 1=1'
      'order by'
      '  db.id_empresa '
      '  ,db.id_banco;'
    )
    Params = <>
    Left = 456
    Top = 272
