  object ZQEndereco: TZQuery
    SQL.Strings = (
      'select '
      '  ee.*'
      '  ,case ee.tipo_endereco'
      '    when 0 then ''Comercial'''
      '    when 1 then ''Residencial'''
      '    when 2 then ''Entrega (Shipping)'''
      '    when 3 then ''Cobrança/Faturamento'''
      '    when 4 then ''Correspondência'''
      '    when 5 then ''Endereço de Instalação (quando envolve serviços técnicos), endereço rural'''
      '    when 6 then ''Endereço Rural (para produtores)'''
      '    when 7 then ''Endereço Temporário (Eventos, obras).'''
      '  end tipo_endereco_desc'
      'from public.endereco_empresa ee'
      'where 1=1'
      'order by '
      '  ee.id_empresa '
      '  ,ee.id_endereco; '
    )
    Params = <>
    Left = 344
    Top = 272
