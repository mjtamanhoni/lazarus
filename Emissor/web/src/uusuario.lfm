  object ZQRegistros: TZQuery[6]
    SQL.Strings = (
      'SELECT '
      '  u.*'
      '  ,case u.ativo '
      '    when 0 then ''INATIVO'''
      '    when 1 then ''ATIVO'''
      '  end ativo_desc'
      '  ,p.nome_perfil '
      '  ,e.nome_fantasia '
      '  ,e.razao_social '
      'FROM public.usuarios u'
      '  join public.perfis p on p.id_perfil = u.id_perfil '
      '  join public.empresa e on e.id_empresa = u.id_empresa '
      'where 1=1'
      'order by '
      '  u.id_usuario;'
    )
    Params = <>
    Left = 165
    Top = 245
